# Variáveis de ambiente (segurança)
.env
.env.*

# Logs de aplicação
logs.txt
*.log

# Pasta scratch (scripts descartáveis e node_modules locais)
scratch/

# Artefatos de testes Cypress
frontend/cypress/downloads/
frontend/cypress/videos/
frontend/cypress_out*.txt
frontend/test_results.txt

# Artefatos temporários do TestSprite
testsprite_tests/tmp/

# Apresentações e documentos comerciais
APRESENTACAO_CLIENTE.*

# Scripts de debug
debug_*.js

# Arquivos de referencia visual
/template-ref/

# Artefatos locais de Design e HTML (Mockups)
template_*.html

# Banco de dados e Backups (Crítico para LGPD / Segurança)
backups/
*.sql
*.sql.gz
*.dump
backup_*

# Flyway migrations must be tracked despite the *.sql rule above
!backend/src/main/resources/db/migration/*.sql